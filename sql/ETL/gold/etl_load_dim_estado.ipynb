   "source": [
    "%sql\n",
    "INSERT INTO bootcamp_matias.gold.dim_estado (estado, _created_at)\n",
    "SELECT\n",
    " DISTINCT\n",
    "  A.estado,\n",
    "  CURRENT_TIMESTAMP()\n",
    "FROM bootcamp_matias.silver.propiedades A\n",
    "WHERE NOT EXISTS (\n",
    "  SELECT  1\n",
    "  FROM bootcamp_matias.gold.dim_estado B \n",
    "  WHERE \n",
    "    A.estado = B.estado\n",
    ")"
   ]
  }
 ],
